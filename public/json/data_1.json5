  "isPrivateVideo": false, //是否使用私有视频  true 是  false 否
  "blzy": "男性， 72 岁。 反复咳嗽、 咳痰 20 年，![](https://images.unsplash.com/photo-1507525428034-b723cf961d3e?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80) 呼吸困难 5 年， 加重 2 天。患者 20 年前无明确诱因出现咳嗽， 咳白色黏痰， 量约 5~10ml/d， 无痰中带血、 发热、 盗汗，无胸痛、 呼吸困难， 无双下肢水肿。 自服“头孢类” 抗生素及止咳祛痰药物， 症状可逐渐缓解。 此后上述症状每于受凉、 感冒后反复发作， 秋冬季明显。 ![](https://picsum.photos/id/237/800/450) 5 年前逐渐出现活动后气短，曾行肺功能检查示“阻塞性通气功能障碍”， 呼吸困难逐渐加重。 2 天前， 患者受凉后再次出现咳嗽、 咳黄白色黏痰， 呼吸困难加重， 稍活动即感气短， 无胸痛及双下肢水肿。 口服“茶碱” 并到社区卫生所吸氧治疗后症状无明显缓解。 本次发病以来， 精神、 食欲、 睡眠欠佳，大小便正常， 体重无变化。 否认高血压、 心脏病及糖尿病病史， 否认传染病接触史。 吸烟25 年， 20 支/日， 已戒 3 年。 偶饮酒。 无遗传病家族史。查体： T36.8℃， P98 次/分， R24 次/分， BP136/76mmHg， 神志清楚， 由他人扶入病房， 浅表淋巴结未触及肿大。 口唇无发绀。 颈静脉无怒张， 桶状胸， 双肺触觉语颤减弱， 叩诊呈过清音， 呼吸音减弱， 可闻及散在哮鸣音， 双肺底少许湿性啰音， 未闻及胸膜摩擦音。 心界不大， 心率 98 次/分， 律齐， 各瓣膜听诊区未闻及杂音， 双下肢无水肿。实验室检查： 动脉血气分析（氧流量 2L/min）： pH7.34， PaCO252mmHg， PaO270mmHg, HCO3-27.5mmol/L。心电图： 窦性心律， 电轴右偏。",//经典例题  如需图片则格式为![](https://images.unsplash.com/photo-1507525428034-b723cf961d3e?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80)
  "dtyq": "根据以上病历摘要, 请将初步诊断、 诊断依据（如有两个或以上诊断， 应分别列出各自诊断,依据）、鉴别诊断、进一步检查与治疗原则写在答题纸上。", //答题要求
  "pfbz": "总分22分", //评分标准
  "kssj":"15分钟", //考试时间
  "pfxz": [ //评分细则
    {
      "text": "1.初步诊断", //标题名称
      "fs": "4分", //分数
      "children": [ //标题名称下级 后续以此类推
        {
          "text": "（1） 慢性阻塞性肺疾病急性加重期（ 仅答“慢性阻塞性肺疾病” 得 1 分）。",
          "fs": "2分"
        },
        {
          "text": "（2）Ⅱ型呼吸衰竭（ 仅答“ 呼吸衰竭” 得 1 分，答“Ⅰ 型呼吸衰竭” 不得,分）",
          "fs": "2分"
        }
      ]
    },
    {
      "text": "2.诊断依据",
      "fs": "5分",
      "children": [
        {
          "text": "（1）慢性阻塞性肺疾病急性加重期:",
          "fs": "",
          "children": [
            {
              "text": "①老年男性，慢性病程，有长期大量吸烟史。",
              "fs": "0.5分"
            },
            {
              "text": "②长期反复咳嗽、咳痰，秋冬季明显，进行性呼吸困难，止咳祛痰及抗感染治疗有效。",
              "fs": "1分"
            },
            {
              "text": "③查体：肺气肿体征（桶状胸，双肺触觉语颤减弱，叩诊呈过清音，双肺呼吸音减弱），双肺散在哮鸣音及湿啰音。",
              "fs": "1分"
            },
            {
              "text": "④肺功能检查:阻塞性通气功能障碍。",
              "fs": "1分"
            }
          ]
        },
        {
          "text": "（2）Ⅱ型呼吸衰竭:",
          "fs": "",
          "children": [
            {
              "text": "①慢性阻塞性肺疾病病史，本次急性加重，呼吸困难。",
              "fs": "0.5分"
            },
            {
              "text": "②动脉血气分析：低氧血症（ PaO2/FiO2<300 mmHg），PaCO2>50mmHg。",
              "fs": "1分"
            }
          ]
        }
      ]
    },
    {
      "text": "3.鉴别诊断",
      "fs": "3分",
      "children": [
        {
          "text": "（1）支气管哮喘。",
          "fs": "1分"
        },
        {
          "text": "（2）支气管扩张症。",
          "fs": "1分"
        },
        {
          "text": "（3）肺结核。",
          "fs": "1分"
        }
      ]
    },
    {
      "text": "4.进一步检查",
      "fs": "5分",
      "children": [
        {
          "text": "（1）血常规， 血电解质， 血糖,肝、 肾功能。",
          "fs": "1分"
        },
        {
          "text": "（2）痰病原学检查（ 痰培养+药敏试验、 痰涂片抗酸染色）。",
          "fs": "1分"
        },
        {
          "text": "（3）胸部 X 线片或胸部 CT。",
          "fs": "1分"
        },
        {
          "text": "（4）超声心动图。",
          "fs": "0.5分"
        },
        {
          "text": "（5）病情平稳后复查肺功能",
          "fs": "1.5分"
        }
      ]
    },
    {
      "text": "5.治疗原则",
      "fs": "5分",
      "children": [
        {
          "text": "（1）持续低流量吸氧， 止咳， 祛痰。",
          "fs": "1分"
        },
        {
          "text": "（2）广谱抗生素抗感染治疗。",
          "fs": "1.5分"
        },
        {
          "text": "（3）联合使用支气管舒张剂+糖皮质激素平喘治疗。",
          "fs": "1.5分"
        },
        {
          "text": "（4）必要时机械通气。",
          "fs": "0.5分"
        },
        {
          "text": "（5）健康教育。",
          "fs": "0.5分"
        }
      ]
    }
  ]
